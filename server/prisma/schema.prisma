generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Enums ===

enum GameStatus {
  draft
  active
  completed
  archived
}

enum AnswerTemplateType {
  single_answer
  multiple_choice
  multiple_text
  photo_select
}

enum ShowtimePhase {
  filling
  syncing
  revealed
}

// === Models ===

model Game {
  id              String     @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  status          GameStatus @default(draft)
  currentAct      Int        @default(1) @map("current_act")
  blurNudgeEnabled Boolean   @default(false) @map("blur_nudge_enabled")
  duplicatedFromId String?   @map("duplicated_from_id") @db.Uuid
  duplicatedFrom  Game?      @relation("GameLineage", fields: [duplicatedFromId], references: [id])
  duplicates      Game[]     @relation("GameLineage")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  cards          Card[]
  designs        Design[]
  cardSets       CardSet[]
  houses         House[]
  missions       Mission[]
  showtimes      Showtime[]
  singleAnswers  SingleAnswer[]
  multipleAnswers MultipleAnswer[]
  scanEvents            ScanEvent[]
  answerAttempts        AnswerAttempt[]
  missionScanEvents     MissionScanEvent[]
  missionAnswerAttempts MissionAnswerAttempt[]
  triggeredConsequences TriggeredConsequence[]
  storySheets           StorySheet[]
  setReviews            SetReview[]

  @@map("games")
}

model CardSet {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  game      Game     @relation(fields: [gameId], references: [id])
  name      String
  color     String   @default("#8b5cf6")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cards      Card[]
  setReviews SetReview[]

  @@unique([gameId, name])
  @@map("card_sets")
}

model House {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  game      Game     @relation(fields: [gameId], references: [id])
  name      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cards                  CardHouse[]
  tableCards             Card[]          @relation("TableAssignment")
  missionHouses          MissionHouse[]
  showtimeSlots          ShowtimeSlot[]
  triggeredConsequences  TriggeredConsequence[]
  storySheets            StorySheet[]

  @@unique([gameId, name])
  @@map("houses")
}

model CardHouse {
  id      String @id @default(uuid()) @db.Uuid
  cardId  String @map("card_id") @db.Uuid
  card    Card   @relation(fields: [cardId], references: [id])
  houseId String @map("house_id") @db.Uuid
  house   House  @relation(fields: [houseId], references: [id])

  @@unique([cardId, houseId])
  @@map("card_houses")
}

model Card {
  id                  String              @id @default(uuid()) @db.Uuid
  gameId              String              @map("game_id") @db.Uuid
  game                Game                @relation(fields: [gameId], references: [id])
  physicalCardId      String              @map("physical_card_id") @db.Uuid
  act                 Int                 @default(1)
  cardSetId           String?             @map("card_set_id") @db.Uuid
  cardSet             CardSet?            @relation(fields: [cardSetId], references: [id])
  clueVisibleCategory String?             @map("clue_visible_category")
  complexity          String              @default("simple")
  header              String?
  description         String?
  clueContent         String?             @map("clue_content")
  answerTemplateType  AnswerTemplateType? @map("answer_template_type")
  answerId            String?             @map("answer_id") @db.Uuid
  isAnswerable        Boolean             @default(false) @map("is_answerable")
  lockedOut           Boolean             @default(false) @map("locked_out")
  lockedOutReason     String?             @map("locked_out_reason")
  selfDestructTimer   Int?                @map("self_destruct_timer")
  selfDestructedAt    DateTime?           @map("self_destructed_at")
  selfDestructText    String?             @map("self_destruct_text")
  designId            String?             @map("design_id") @db.Uuid
  design              Design?             @relation(fields: [designId], references: [id])
  examinedAt                DateTime? @map("examined_at")
  examineText               String?   @map("examine_text")
  answerVisibleAfterDestruct Boolean  @default(true) @map("answer_visible_after_destruct")
  tableHouseId        String?             @map("table_house_id") @db.Uuid
  tableHouse          House?              @relation("TableAssignment", fields: [tableHouseId], references: [id])
  sortOrder           Int                 @default(0) @map("sort_order")
  notes               String?
  isFinished          Boolean             @default(false) @map("is_finished")
  isSolved            Boolean             @default(false) @map("is_solved")
  deletedAt           DateTime?           @map("deleted_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  cardHouses     CardHouse[]
  missions       Mission[]
  scanEvents     ScanEvent[]
  answerAttempts AnswerAttempt[]

  @@unique([gameId, physicalCardId, act])
  @@map("cards")
}

model Design {
  id              String   @id @default(uuid()) @db.Uuid
  gameId          String   @map("game_id") @db.Uuid
  game            Game     @relation(fields: [gameId], references: [id])
  name            String
  bgColor         String   @default("#0a0a0a") @map("bg_color")
  bgGradient      String?  @map("bg_gradient")
  bgImageUrl      String?  @map("bg_image_url")
  textColor       String   @default("#e0e0e0") @map("text_color")
  accentColor     String   @default("#4fc3f7") @map("accent_color")
  secondaryColor  String?  @map("secondary_color")
  fontFamily      String   @default("system-ui") @map("font_family")
  cardStyle       String   @default("standard") @map("card_style")
  animationIn     String?  @map("animation_in")
  borderStyle     String?  @map("border_style")
  overlayEffect   String?  @map("overlay_effect")
  customCss       String?  @map("custom_css")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cards     Card[]
  missions  Mission[]
  showtimes Showtime[]

  @@map("designs")
}

model SingleAnswer {
  id                String   @id @default(uuid()) @db.Uuid
  gameId            String   @map("game_id") @db.Uuid
  game              Game     @relation(fields: [gameId], references: [id])
  correctAnswer     String   @map("correct_answer")
  caseSensitive     Boolean  @default(false) @map("case_sensitive")
  trimWhitespace    Boolean  @default(true) @map("trim_whitespace")
  acceptAlternatives String[] @map("accept_alternatives")
  hint              String?
  hintAfterAttempts Int      @default(3) @map("hint_after_attempts")
  maxAttempts       Int?     @map("max_attempts")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("single_answers")
}

model MultipleAnswer {
  id                String   @id @default(uuid()) @db.Uuid
  gameId            String   @map("game_id") @db.Uuid
  game              Game     @relation(fields: [gameId], references: [id])
  fields            Json     @default("[]")
  // fields = array of:
  // {
  //   prompt: string | null,           // optional label/title shown above this input
  //   correctAnswer: string,
  //   acceptAlternatives: string[],
  //   caseSensitive: boolean,
  //   trimWhitespace: boolean
  // }
  hint              String?
  hintAfterAttempts Int      @default(3) @map("hint_after_attempts")
  maxAttempts       Int?     @map("max_attempts")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("multiple_answers")
}

model ScanEvent {
  id          String   @id @default(uuid()) @db.Uuid
  cardId      String   @map("card_id") @db.Uuid
  card        Card     @relation(fields: [cardId], references: [id])
  gameId      String   @map("game_id") @db.Uuid
  game        Game     @relation(fields: [gameId], references: [id])
  scannedAt   DateTime @default(now()) @map("scanned_at")
  sessionHash String?  @map("session_hash")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("scan_events")
}

model AnswerAttempt {
  id              String   @id @default(uuid()) @db.Uuid
  cardId          String   @map("card_id") @db.Uuid
  card            Card     @relation(fields: [cardId], references: [id])
  gameId          String   @map("game_id") @db.Uuid
  game            Game     @relation(fields: [gameId], references: [id])
  attemptNumber   Int      @map("attempt_number")
  answerGiven     Json     @map("answer_given")
  isCorrect       Boolean  @map("is_correct")
  attemptedAt     DateTime @default(now()) @map("attempted_at")
  timeSinceScanMs Int?     @map("time_since_scan_ms")
  sessionHash     String?  @map("session_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("answer_attempts")
}

model SetReview {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  game      Game     @relation(fields: [gameId], references: [id])
  cardSetId String   @map("card_set_id") @db.Uuid
  cardSet   CardSet  @relation(fields: [cardSetId], references: [id])
  reviewedAt DateTime @default(now()) @map("reviewed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([gameId, cardSetId])
  @@map("set_reviews")
}

// === Missions ===

model Mission {
  id                          String              @id @default(uuid()) @db.Uuid
  gameId                      String              @map("game_id") @db.Uuid
  game                        Game                @relation(fields: [gameId], references: [id])
  act                         Int
  missionCardId               String?             @map("mission_card_id") @db.Uuid
  missionCard                 Card?               @relation(fields: [missionCardId], references: [id])
  title                       String
  sheetLetter                 String?             @map("sheet_letter")
  description                 String
  puzzleDescription           String?             @map("puzzle_description")
  requiredClueSets            Json                @default("[]") @map("required_clue_sets")
                              // Array of { cardSetId: string, count: number }
  answerTemplateType          AnswerTemplateType? @map("answer_template_type")
  answerId                    String?             @map("answer_id") @db.Uuid
  designId                    String?             @map("design_id") @db.Uuid
  design                      Design?             @relation(fields: [designId], references: [id])
  isCompleted                 Boolean             @default(false) @map("is_completed")
  completedAt                 DateTime?           @map("completed_at")
  lockedOut                   Boolean             @default(false) @map("locked_out")
  lockedOutReason             String?             @map("locked_out_reason")
  consequenceCompleted        String?             @map("consequence_completed")
  consequenceNotCompleted     String?             @map("consequence_not_completed")
  consequenceImageCompleted   String?             @map("consequence_image_completed")
  consequenceImageNotCompleted String?            @map("consequence_image_not_completed")
  sortOrder                   Int                 @default(0) @map("sort_order")
  notes                       String?
  createdAt                   DateTime            @default(now()) @map("created_at")
  updatedAt                   DateTime            @updatedAt @map("updated_at")

  missionHouses         MissionHouse[]
  missionScanEvents     MissionScanEvent[]
  missionAnswerAttempts MissionAnswerAttempt[]
  consequencesAsSource  MissionConsequence[] @relation("ConsequenceSource")
  consequencesAsTarget  MissionConsequence[] @relation("ConsequenceTarget")

  @@map("missions")
}

model MissionHouse {
  id        String  @id @default(uuid()) @db.Uuid
  missionId String  @map("mission_id") @db.Uuid
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  houseId   String  @map("house_id") @db.Uuid
  house     House   @relation(fields: [houseId], references: [id])

  @@unique([missionId, houseId])
  @@map("mission_houses")
}

model MissionConsequence {
  id                String   @id @default(uuid()) @db.Uuid
  sourceMissionId   String   @map("source_mission_id") @db.Uuid
  sourceMission     Mission  @relation("ConsequenceSource", fields: [sourceMissionId], references: [id], onDelete: Cascade)
  targetMissionId   String?  @map("target_mission_id") @db.Uuid
  targetMission     Mission? @relation("ConsequenceTarget", fields: [targetMissionId], references: [id], onDelete: SetNull)
  triggerOnFailure  Boolean  @default(true) @map("trigger_on_failure")
  triggerOnSuccess  Boolean  @default(false) @map("trigger_on_success")
  type              String   // "warning" | "lock" | "redistribute"
  message           String
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  triggeredConsequences TriggeredConsequence[]

  @@map("mission_consequences")
}

model TriggeredConsequence {
  id              String             @id @default(uuid()) @db.Uuid
  gameId          String             @map("game_id") @db.Uuid
  game            Game               @relation(fields: [gameId], references: [id])
  consequenceId   String             @map("consequence_id") @db.Uuid
  consequence     MissionConsequence @relation(fields: [consequenceId], references: [id], onDelete: Cascade)
  houseId         String             @map("house_id") @db.Uuid
  house           House              @relation(fields: [houseId], references: [id])
  triggeredAtAct  Int                @map("triggered_at_act")
  triggeredAt     DateTime           @default(now()) @map("triggered_at")
  acknowledged    Boolean            @default(false)
  createdAt       DateTime           @default(now()) @map("created_at")

  @@map("triggered_consequences")
}

model MissionScanEvent {
  id          String   @id @default(uuid()) @db.Uuid
  missionId   String   @map("mission_id") @db.Uuid
  mission     Mission  @relation(fields: [missionId], references: [id])
  gameId      String   @map("game_id") @db.Uuid
  game        Game     @relation(fields: [gameId], references: [id])
  houseId     String?  @map("house_id") @db.Uuid
  scannedAt   DateTime @default(now()) @map("scanned_at")
  sessionHash String?  @map("session_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("mission_scan_events")
}

model MissionAnswerAttempt {
  id              String   @id @default(uuid()) @db.Uuid
  missionId       String   @map("mission_id") @db.Uuid
  mission         Mission  @relation(fields: [missionId], references: [id])
  gameId          String   @map("game_id") @db.Uuid
  game            Game     @relation(fields: [gameId], references: [id])
  houseId         String?  @map("house_id") @db.Uuid
  attemptNumber   Int      @map("attempt_number")
  answerGiven     Json     @map("answer_given")
  isCorrect       Boolean  @map("is_correct")
  attemptedAt     DateTime @default(now()) @map("attempted_at")
  sessionHash     String?  @map("session_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("mission_answer_attempts")
}

// === Showtimes ===

model Showtime {
  id               String        @id @default(uuid()) @db.Uuid
  gameId           String        @map("game_id") @db.Uuid
  game             Game          @relation(fields: [gameId], references: [id])
  act              Int
  title            String
  revealTitle      String        @map("reveal_title")
  revealDescription String?      @map("reveal_description")
  designId         String?       @map("design_id") @db.Uuid
  design           Design?       @relation(fields: [designId], references: [id])
  phase            ShowtimePhase @default(filling)
  showHouseLabels  Boolean       @default(true) @map("show_house_labels")
  syncWindowMs     Int           @default(3000) @map("sync_window_ms")
  revealedAt       DateTime?     @map("revealed_at")
  sortOrder        Int           @default(0) @map("sort_order")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  slots ShowtimeSlot[]

  @@map("showtimes")
}

model ShowtimeSlot {
  id                 String              @id @default(uuid()) @db.Uuid
  showtimeId         String              @map("showtime_id") @db.Uuid
  showtime           Showtime            @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  houseId            String              @map("house_id") @db.Uuid
  house              House               @relation(fields: [houseId], references: [id])
  label              String
  description        String?
  sortOrder          Int                 @default(0) @map("sort_order")
  answerTemplateType AnswerTemplateType? @map("answer_template_type")
  answerId           String?             @map("answer_id") @db.Uuid
  inputValue         String?             @map("input_value")
  filledAt           DateTime?           @map("filled_at")
  isCorrect          Boolean?            @map("is_correct")
  syncPressedAt      DateTime?           @map("sync_pressed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@unique([showtimeId, houseId])
  @@map("showtime_slots")
}

// === Story Sheets ===

model StorySheet {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  game      Game     @relation(fields: [gameId], references: [id])
  houseId   String   @map("house_id") @db.Uuid
  house     House    @relation(fields: [houseId], references: [id])
  act       Int
  title     String   @default("Story Sheet")
  content   String   @default("")
  notes     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([gameId, houseId, act])
  @@map("story_sheets")
}
